# Gemini API key from Google AI Studio. Omit entirely to run in offline mode.
# GOOGLE_API_KEY is also accepted by the SDK and wins if both are set.
GEMINI_API_KEY=

# Optional: override the Gemini model id (must support function calling).
# Default is gemini-2.5-flash (free-tier eligible). Pick a different id for
# your key's tier if needed; if the id is not available the app degrades
# gracefully to offline mode.
# GEMINI_MODEL=gemini-2.5-flash

# Optional: distributed rate limiting across replicas behind a load balancer.
# Leave unset to use the in-memory limiter (fine for a single process). If set
# but unreachable, the app logs a warning and falls back to in-memory.
# REDIS_URL=redis://localhost:6379/0

# Required to unlock the Operations dashboard. Set strong values only in your
# deployment environment or a local .env file; never commit real credentials.
ADMIN_USERNAME=replace-with-admin-id
ADMIN_PASSWORD=replace-with-a-long-random-password